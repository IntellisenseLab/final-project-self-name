<?xml version="1.0"?>
<robot name="qbot">

  
  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.1"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.178" length="0.109"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.178" length="0.109"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_left_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_right_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>


  <link name="caster_front_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
    </visual>
  </link>

  <link name="caster_back_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
    </visual>
  </link>


  <link name="sensor_mount_link">
    <visual>
      <geometry>
        <box size="0.08 0.12 0.05"/>
      </geometry>
    </visual>
  </link>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </visual>
  </link>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
    </visual>
  </link>

 <link name="lidar_link">
  <visual>
    <geometry><cylinder radius="0.03" length="0.05"/></geometry>
  </visual>
</link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 0.193 0.025" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.193 0.025" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin xyz="0.115 0 0.007"/>
  </joint>

  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.135 0 0.009"/>
  </joint>

  <joint name="sensor_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mount_link"/>
    <origin xyz="0 0 0.139"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="sensor_mount_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="lidar_link"/>
  <origin xyz="0 0 0.12" rpy="0 0 0"/>
</joint>

   <gazebo reference="lidar_link">
   <sensor name="lidar" type="gpu_lidar">
     <gz_frame_id>lidar_link</gz_frame_id> 
     <topic>scan</topic>
     <update_rate>10</update_rate>
     <ray>
       <scan>
         <horizontal>
           <samples>360</samples>
           <resolution>1</resolution>
           <min_angle>-3.14</min_angle>
           <max_angle>3.14</max_angle>
         </horizontal>
       </scan>
       <range>
         <min>0.1</min>
         <max>12.0</max>
       </range>
     </ray>
     <visualize>true</visualize>
   </sensor>
 </gazebo>


  <ros2_control name="qbot_system" type="system">
  <hardware>
   
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>

  <joint name="wheel_left_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="wheel_right_joint">
    <command_interface name="velocity"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>



<gazebo>
  <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <parameters>/home/hg/Documents/Robotics Labs/Project/final-project-self-name/ros_project_ws/src/qbot_description/config/qbot_controllers.yaml</parameters>
  </plugin>
</gazebo>



</robot>